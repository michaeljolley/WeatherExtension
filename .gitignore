## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.env

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results — never commit binaries or NuGet caches.
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
[Aa][Rr][Mm]64[Ee][Cc]/

# MSIX packaging output
AppPackages/
*.msix
*.msixupload
*.appx
*.appxupload
*.appxbundle
*.appxsym

# Local dev signing keys (never commit private keys or certs)
WeatherExtension/signing/
*.pfx
*.cer
*.snk

# Logs and one-off build artifacts
weather-extension.log
build_log.txt

# Visual Studio IDE state
.vs/
